# =========================================================================
# HJG Data Hub environment
# Data model: CoachAccountable is mirrored INTO Supabase (Postgres) by the
# sync job. The dashboard reads from Supabase; staff sign in with Supabase Auth.
# =========================================================================

# --- Supabase: SERVER side (sync job + report endpoints) ---
# From Supabase: Project Settings > API.
SUPABASE_URL=
# The service_role / secret key. SERVER ONLY. Never expose to the browser.
# It bypasses row-level security so the sync job can write the mirror tables.
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase: BROWSER side (the dashboard, via Vite) ---
# Same project URL, and the anon / publishable key (safe for the browser; RLS
# protects the data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- CoachAccountable API (server-side only; the sync job reads from CA) ---
CA_API_ID=
CA_API_KEY=

# --- Sync budget governance (a safety cap on CA calls per sync day) ---
# The plan's daily call limit and our self-imposed percentage cap also live in
# the app_settings table (editable from the Admin screen); these env values are
# the fallback defaults when the settings rows are absent.
CA_PLAN_DAILY_LIMIT=600
HJG_DAILY_CAP_PCT=5
# Timezone used to roll the daily call counter and to bucket appointment months.
BUDGET_TZ=America/Chicago

# --- Which years the sync pulls appointments/submissions for ---
# Comma-separated. Default: the current year and the two prior years.
SYNC_YEARS=

# --- CORS: comma-separated allowed origins. Default "*" for local dev. ---
HJG_CORS_ALLOWED_ORIGINS=*

# --- Optional shared secret for the (currently dormant) scheduled sync cron ---
# Lets a Vercel Cron job call /api/sync without a user session. Leave blank
# while sync is manual-only.
SYNC_CRON_SECRET=
