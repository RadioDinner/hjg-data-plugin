# --- CoachAccountable API (server-side only; never expose to the browser) ---
CA_API_ID=
CA_API_KEY=

# --- API access token (dashboard sends this on every request) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, auth is skipped in non-production. In production a missing token
# makes protected endpoints fail closed (see lib/http.ts).
HJG_API_TOKEN=

# --- CORS: comma-separated allowed origins. Default "*" for local dev. ---
HJG_CORS_ALLOWED_ORIGINS=*

# --- API budget governance ---
# Daily call budget of the CA plan. Default 600 = safest assumption (Level 3).
# Confirm HJG's real tier from the CA billing page, then raise this.
CA_PLAN_DAILY_LIMIT=600
# Hard cap as a percentage of the daily budget. Default 5%.
HJG_DAILY_CAP_PCT=5
# How long a stored snapshot is considered fresh before a request may refresh it.
SNAPSHOT_TTL_SECONDS=3600
# Timezone used to roll the daily call counter (and to bucket appointment months).
BUDGET_TZ=America/Chicago

# --- Vercel KV (injected automatically when you attach a KV store) ---
# Without these, the app falls back to in-memory state (fine for local dev,
# but the budget counter will not persist across serverless invocations).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Frontend (Vite) ---
# Token the dashboard sends to the API. For local dev only; in production the
# token is configured wherever the dashboard is hosted.
VITE_HJG_API_TOKEN=
# Set to "1" to force the dashboard to render bundled mock data (no API calls).
VITE_USE_MOCK=
